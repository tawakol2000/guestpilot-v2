{
  "_description": "Tier 3 Topic State Cache — ALWAYS re-inject previous topic unless topic switch detected",
  "_logic": "Default: re-inject. Exception: topic switch keywords found → reset cache.",
  
  "topic_switch_keywords": {
    "_description": "If ANY of these appear, the guest is changing topics. RESET the cache.",
    "explicit_en": [
      "also",
      "and also",
      "also can",
      "also is",
      "also what",
      "also do",
      "by the way",
      "btw",
      "another thing",
      "another question",
      "one more thing",
      "one more question",
      "different question",
      "quick question",
      "new question",
      "separately",
      "on another note",
      "oh and",
      "and one more",
      "one last thing",
      "while I'm at it",
      "since I have you",
      "while we're at it",
      "before I forget",
      "I also wanted",
      "I also need",
      "can you also",
      "could you also",
      "what about"
    ],
    "explicit_ar": [
      "وكمان",
      "وبعدين",
      "سؤال ثاني",
      "شي ثاني",
      "بالمناسبة",
      "وبالاضافة",
      "حاجة تانية",
      "سؤال تاني",
      "وكمان عايز",
      "وعندي سؤال"
    ]
  },
  
  "not_switch_signals": {
    "_description": "These look like they could be switches but are NOT. Guest is still on the same topic. Do NOT reset cache.",
    "short_answers": [
      "yes", "no", "ok", "okay", "sure", "thanks", "thank you", "great",
      "perfect", "alright", "fine", "got it", "understood", "right",
      "correct", "exactly", "yep", "nope", "maybe", "I think so",
      "not sure", "let me check", "I'll confirm", "sounds good",
      "that works", "no problem", "never mind", "forget it"
    ],
    "short_answers_ar": [
      "نعم", "لا", "تمام", "شكرا", "اوكي", "ماشي", "طيب", "حلو",
      "ممتاز", "ان شاء الله", "الحمد لله", "يعطيك العافية", "جزاك الله خير",
      "مشكور", "الله يعافيك", "اكيد", "بالضبط"
