generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  passwordHash         String
  hostawayApiKey       String
  hostawayAccountId    String
  webhookSecret        String                @default("")
  plan                 Plan                  @default(FREE)
  propertyCount        Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  lastSyncedAt         DateTime?
  conversations        Conversation[]
  guests               Guest[]
  messages             Message[]
  pendingReplies       PendingAiReply[]
  properties           Property[]
  reservations         Reservation[]
  tasks                Task[]
  faqEntries           FaqEntry[]
  webhookLogs          WebhookLog[]
  messageTemplates     MessageTemplate[]
  knowledgeSuggestions KnowledgeSuggestion[]
  aiApiLogs            AiApiLog[]
  aiConfigVersions     AiConfigVersion[]
  tenantAiConfig       TenantAiConfig?
  sopDefinitions       SopDefinition[]
  toolDefinitions      ToolDefinition[]
  pushSubscriptions    PushSubscription[]
  iosPushTokens        IosPushToken[]
  inquiryActionLogs    InquiryActionLog[]
  bookingAlterations   BookingAlteration[]
  alterationActionLogs AlterationActionLog[]
  tuningSuggestions    TuningSuggestion[] // Feature 040: Copilot Shadow Mode
  tuningConversations  TuningConversation[] // Feature 041: Conversational Tuning
  agentMemories        AgentMemory[] // Feature 041
  evidenceBundles      EvidenceBundle[] // Feature 041
  capabilityRequests   CapabilityRequest[] // Feature 041
  preferencePairs      PreferencePair[] // Feature 041
  tuningCategoryStats  TuningCategoryStats[] // Feature 041 sprint 02
  sopVariantHistory    SopVariantHistory[] // Feature 041 sprint 05
  faqEntryHistory      FaqEntryHistory[] // Feature 041 sprint 05

  // Dashboard connection (platform.hostaway.com internal API)
  dashboardJwt          String?   @db.Text
  dashboardJwtIssuedAt  DateTime?
  dashboardJwtExpiresAt DateTime?
  dashboardConnectedBy  String?

  // ─── Feature 043: tenant-level defaults for per-property auto-accept thresholds ───
  defaultAutoAcceptLateCheckoutUntil String?
  defaultAutoAcceptEarlyCheckinFrom  String?

  // ─── Feature 043 relations ───
  automatedReplyTemplates AutomatedReplyTemplate[]
  taskActionLogs          TaskActionLog[]

  // ─── Feature 044: WhatsApp doc-handoff config ───
  docHandoffManagerRecipient  String?
  docHandoffSecurityRecipient String?
  docHandoffReminderTime      String                 @default("22:00")
  docHandoffTime              String                 @default("10:00")
  docHandoffEnabled           Boolean                @default(false)
  documentHandoffStates       DocumentHandoffState[]
  buildTransactions           BuildTransaction[] // Feature 045: BUILD mode
}

model Property {
  id                          String                @id @default(cuid())
  tenantId                    String
  hostawayListingId           String
  name                        String
  address                     String                @default("")
  listingDescription          String                @default("")
  customKnowledgeBase         Json                  @default("{}")
  // ─── Feature 043: per-property auto-accept thresholds (HH:MM, null = off, fall back to tenant default) ───
  autoAcceptLateCheckoutUntil String?
  autoAcceptEarlyCheckinFrom  String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  conversations               Conversation[]
  tenant                      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations                Reservation[]
  tasks                       Task[]
  faqEntries                  FaqEntry[]
  knowledgeSuggestions        KnowledgeSuggestion[]
  sopPropertyOverrides        SopPropertyOverride[]

  @@unique([tenantId, hostawayListingId])
  @@index([tenantId])
}

model Guest {
  id              String         @id @default(cuid())
  tenantId        String
  hostawayGuestId String
  name            String
  email           String         @default("")
  phone           String         @default("")
  nationality     String         @default("")
  createdAt       DateTime       @default(now())
  conversations   Conversation[]
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations    Reservation[]

  @@unique([tenantId, hostawayGuestId])
  @@index([tenantId])
}

model Reservation {
  id                    String            @id @default(cuid())
  tenantId              String
  propertyId            String
  guestId               String
  hostawayReservationId String
  checkIn               DateTime
  checkOut              DateTime
  guestCount            Int               @default(1)
  channel               Channel           @default(OTHER)
  status                ReservationStatus @default(CONFIRMED)
  screeningAnswers      Json              @default("{}")
  aiEnabled             Boolean           @default(true)
  aiMode                String            @default("autopilot")
  totalPrice            Decimal?
  hostPayout            Decimal?
  cleaningFee           Decimal?
  currency              String?
  // ─── Feature 043: per-reservation HH:MM overrides of the property default check-in/out times ───
  // Written only by scheduled-time.service.ts (auto-accept) and task-actions.controller.ts (manual Accept).
  scheduledCheckInAt    String?
  scheduledCheckOutAt   String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  conversations         Conversation[]
  guest                 Guest             @relation(fields: [guestId], references: [id])
  property              Property          @relation(fields: [propertyId], references: [id])
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  inquiryActionLogs    InquiryActionLog[]
  alteration           BookingAlteration?
  alterationActionLogs AlterationActionLog[]

  // ─── Feature 044 ───
  documentHandoffStates DocumentHandoffState[]

  @@unique([tenantId, hostawayReservationId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([tenantId, checkIn])
  @@index([tenantId, checkOut])
}

model Conversation {
  id                     String                @id @default(cuid())
  tenantId               String
  reservationId          String
  guestId                String
  propertyId             String
  channel                Channel               @default(OTHER)
  status                 ConversationStatus    @default(OPEN)
  unreadCount            Int                   @default(0)
  starred                Boolean               @default(false)
  lastMessageAt          DateTime              @default(now())
  hostawayConversationId String                @default("")
  conversationSummary    String?               @db.Text
  summaryUpdatedAt       DateTime?
  summaryMessageCount    Int                   @default(0)
  lastSyncedAt           DateTime?
  createdAt              DateTime              @default(now())
  guest                  Guest                 @relation(fields: [guestId], references: [id])
  property               Property              @relation(fields: [propertyId], references: [id])
  reservation            Reservation           @relation(fields: [reservationId], references: [id])
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages               Message[]
  pendingReplies         PendingAiReply[]
  tasks                  Task[]
  knowledgeSuggestions   KnowledgeSuggestion[]

  @@unique([tenantId, reservationId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, lastMessageAt(sort: Desc)])
}

model Message {
  id                   String               @id @default(cuid())
  conversationId       String
  tenantId             String
  role                 MessageRole
  content              String
  compactedContent     String?              @db.Text // Nano-compressed version of long automated HOST/AI messages, used in conversation history to save tokens. Null = fall back to `content`.
  channel              Channel              @default(OTHER)
  communicationType    String               @default("")
  sentAt               DateTime             @default(now())
  hostawayMessageId    String               @default("")
  imageUrls            String[]             @default([])
  // ─── Feature 040: Copilot Shadow Mode (nullable; safe to drop on retirement) ───
  previewState         PreviewState? // null for normal messages; set for shadow-mode previews
  originalAiText       String?              @db.Text // AI's original generated text (present for previews and kept after Send for audit)
  editedByUserId       String? // Populated on Send if the admin edited before sending
  aiApiLogId           String? // FK to AiApiLog for the generation turn (lets tuning analyzer pull full context)
  // ─── iOS readiness: delivery tracking + client source audit trail ───
  deliveryStatus       String? // 'sent' | 'pending' | 'failed' | null (null for inbound/guest messages)
  deliveryError        String? // Error message when deliveryStatus = 'failed'
  deliveredAt          DateTime? // Timestamp of successful Hostaway delivery
  source               String? // 'web' | 'ios' | 'ai' | 'system' | null (audit trail for who sent)
  // ─── Feature 041 sprint 05 §3 (C19): authoritative edit-magnitude score ───
  // Persisted at trigger time (manager-edited copilot send) by the diagnostic
  // pipeline. Float in [0,1] = 1 - semanticSimilarity(original, final). Old
  // rows (pre sprint-05) stay null; the graduation dashboard averages only
  // non-null values, so legacy rows are excluded cleanly.
  editMagnitudeScore   Float?
  // AI self-rated confidence for this reply (0-1). Populated when the reply
  // came from the structured-output pipeline. Null for pre-feature rows,
  // non-AI messages, and rows where parsing failed.
  aiConfidence         Float?
  // ─── Feature 042: inbound translation cache ───
  // English translation of `content`, populated lazily on first demand by the
  // /api/messages/:id/translate endpoint. Shared across all managers, devices,
  // and the iOS app. Only inbound (role = GUEST) messages are ever translated;
  // null for outbound/system/AI messages and for untouched inbound messages.
  contentTranslationEn String?              @db.Text
  conversation         Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rating               MessageRating?
  tuningSuggestions    TuningSuggestion[]   @relation("SourcePreview")
  tuningConversations  TuningConversation[] @relation("AnchorMessage") // Feature 041
  evidenceBundles      EvidenceBundle[] // Feature 041

  // Partial unique index exists in DB: CREATE UNIQUE INDEX "Message_conv_hostaway_msg_unique" ON "Message" ("conversationId", "hostawayMessageId") WHERE "hostawayMessageId" != ''
  // Applied via prisma/migrations/add_audit_constraints.sql — Prisma 5.x does not support partial indexes in schema
  @@index([conversationId])
  @@index([tenantId])
  @@index([conversationId, previewState])
  // Sprint 09 fix 17 — dashboard coverage + graduation metrics filter by
  // (tenantId, role=AI) then order/window by sentAt. This composite
  // avoids an in-memory sort on the hot path.
  @@index([tenantId, role, sentAt(sort: Desc)])
}

model PendingAiReply {
  id             String       @id @default(cuid())
  conversationId String
  tenantId       String
  scheduledAt    DateTime
  fired          Boolean      @default(false)
  suggestion     String?      @db.Text
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([conversationId])
  @@index([fired, scheduledAt])
}

model Task {
  id             String          @id @default(cuid())
  tenantId       String
  conversationId String?
  propertyId     String?
  title          String
  note           String?
  urgency        String
  type           String          @default("other")
  status         String          @default("open")
  source         String          @default("ai")
  dueDate        DateTime?
  assignee       String?
  completedAt    DateTime?
  // ─── Feature 043: per-type structured payload for typed escalations (e.g., { requestedTime: "13:00", kind: "check_out" }) ───
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  conversation   Conversation?   @relation(fields: [conversationId], references: [id])
  property       Property?       @relation(fields: [propertyId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actionLogs     TaskActionLog[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([conversationId])
}

// ─── Feature 043: per-tenant reply templates for action-card escalations ──────
// Tenant can edit approve/reject copy per escalation type; system defaults fall
// back when no row exists.
model AutomatedReplyTemplate {
  id             String   @id @default(cuid())
  tenantId       String
  escalationType String // 'late_checkout_request' | 'early_checkin_request' | future types
  decision       String // 'approve' | 'reject'
  body           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, escalationType, decision])
  @@index([tenantId])
}

// ─── Feature 043: immutable audit log of every manager / auto-accept action ──
model TaskActionLog {
  id            String   @id @default(cuid())
  tenantId      String
  taskId        String
  action        String // 'accepted' | 'rejected' | 'auto_accepted'
  actorKind     String // 'manager' | 'ai_autoaccept'
  actorUserId   String?
  deliveredBody String   @db.Text
  requestedTime String? // HH:MM echo of what the guest asked for
  appliedTime   String? // HH:MM of what we actually wrote (accept only)
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([taskId])
}

model MessageTemplate {
  id            String   @id @default(cuid())
  tenantId      String
  hostawayId    String?
  name          String
  body          String   @db.Text
  enhancedBody  String?  @db.Text
  triggerType   String?
  triggerOffset Int?
  isEnabled     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, hostawayId])
  @@index([tenantId])
}

model KnowledgeSuggestion {
  id             String   @id @default(cuid())
  tenantId       String
  propertyId     String?
  conversationId String?
  question       String   @db.Text
  answer         String   @db.Text
  status         String   @default("pending")
  source         String   @default("ai")
  category       String?
  usageCount     Int      @default(0)
  avgConfidence  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property?     @relation(fields: [propertyId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@index([tenantId, status])
}

model MessageRating {
  id        String   @id @default(cuid())
  messageId String   @unique
  rating    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
}

enum Plan {
  FREE
  PRO
  SCALE
}

enum Channel {
  AIRBNB
  BOOKING
  DIRECT
  OTHER
  WHATSAPP
}

enum ReservationStatus {
  INQUIRY
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum ConversationStatus {
  OPEN
  RESOLVED
}

enum MessageRole {
  GUEST
  AI
  HOST
  AI_PRIVATE
  MANAGER_PRIVATE
}

// ─── FAQ Knowledge System ────────────────────────────────────────────────────

model FaqEntry {
  id                   String            @id @default(cuid())
  tenantId             String
  propertyId           String?
  question             String
  answer               String            @db.Text
  category             String
  scope                FaqScope          @default(PROPERTY)
  status               FaqStatus         @default(SUGGESTED)
  source               FaqSource         @default(MANUAL)
  usageCount           Int               @default(0)
  lastUsedAt           DateTime?
  sourceConversationId String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  // Feature 045: set when this FAQ was created as part of a BUILD-mode plan.
  buildTransactionId   String?
  buildTransaction     BuildTransaction? @relation(fields: [buildTransactionId], references: [id])
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property             Property?         @relation(fields: [propertyId], references: [id])

  @@unique([tenantId, propertyId, question])
  @@index([tenantId, propertyId, status])
  @@index([tenantId, scope, status])
  @@index([tenantId, category, status])
}

enum FaqScope {
  GLOBAL
  PROPERTY
}

enum FaqStatus {
  SUGGESTED
  ACTIVE
  STALE
  ARCHIVED
}

enum FaqSource {
  MANUAL
  AUTO_SUGGESTED
}

// ─── Automated Messages ──────────────────────────────────────────────────────

// ─── Webhook Logs ────────────────────────────────────────────────────────────

model WebhookLog {
  id         String   @id @default(cuid())
  tenantId   String
  event      String
  hostawayId String?
  status     String   @default("processed")
  payload    Json?
  error      String?
  durationMs Int      @default(0)
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, event])
}

// ─── AI API Logs (persistent) ────────────────────────────────────────────────

model AiApiLog {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String?
  agentName      String   @default("")
  model          String
  temperature    Float?
  maxTokens      Int      @default(4096)
  systemPrompt   String   @db.Text
  userContent    String   @db.Text
  responseText   String   @db.Text
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  costUsd        Float    @default(0)
  durationMs     Int      @default(0)
  error          String?
  ragContext     Json?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, agentName])
  @@index([tenantId, conversationId])
}

// ─── Per-Tenant AI Configuration ─────────────────────────────────────────────

model TenantAiConfig {
  id                        String   @id @default(cuid())
  tenantId                  String   @unique
  agentName                 String   @default("Omar")
  agentPersonality          String   @default("") @db.Text
  customInstructions        String   @default("") @db.Text
  model                     String   @default("gpt-5.4-mini-2026-03-17")
  temperature               Float    @default(0.25)
  maxTokens                 Int      @default(1024)
  debounceDelayMs           Int      @default(30000)
  adaptiveDebounce          Boolean  @default(true)
  aiEnabled                 Boolean  @default(true)
  screeningEnabled          Boolean  @default(true)
  memorySummaryEnabled      Boolean  @default(true)
  judgeThreshold            Float    @default(0.75)
  autoFixThreshold          Float    @default(0.70)
  tier2Threshold            Float    @default(0.75)
  highConfidenceThreshold   Float    @default(0.85)
  lowConfidenceThreshold    Float    @default(0.55)
  tier1Mode                 String   @default("active") // "active" | "ghost" | "off"
  tier2Mode                 String   @default("active") // "active" | "ghost" | "off"
  tier3Mode                 String   @default("active") // "active" | "ghost" | "off"
  workingHoursEnabled       Boolean  @default(false)
  workingHoursStart         String   @default("08:00")
  workingHoursEnd           String   @default("01:00")
  workingHoursTimezone      String   @default("UTC")
  judgeMode                 String   @default("evaluate_all")
  sopOverrides              Json     @default("{}")
  reasoningCoordinator      String   @default("auto") // "none" | "low" | "medium" | "high" | "auto"
  reasoningScreening        String   @default("none") // "none" | "low" | "medium" | "high"
  systemPromptCoordinator   String?  @db.Text
  systemPromptScreening     String?  @db.Text
  systemPromptVersion       Int      @default(1)
  imageHandlingInstructions String?  @db.Text // Appended to system prompt when guest sends an image
  systemPromptHistory       Json     @default("[]") // Array of {version, timestamp, coordinator?, screening?, note?}
  // ─── Feature 040: Copilot Shadow Mode (safe to drop on retirement) ───
  shadowModeEnabled         Boolean  @default(false) // When true, copilot replies render as in-chat preview bubbles + fire tuning analyzer on edited sends. Autopilot unaffected.
  // Autopilot: minimum self-rated confidence (0-1) required to auto-send. Below
  // this threshold, the reply is downgraded to a shadow preview so a human reviews it.
  autopilotMinConfidence    Float    @default(0.75)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─── OPUS Audit Reports ─────────────────────────────────────────────────────

// ─── AI Config Version History ───────────────────────────────────────────────

model AiConfigVersion {
  id                 String            @id @default(cuid())
  tenantId           String
  version            Int
  config             Json
  note               String?
  createdAt          DateTime          @default(now())
  // ─── Feature 041 pre-wire (D4 A/B testing); unused in V1 ───
  experimentId       String?
  trafficPercent     Int?
  // Feature 045: set when this version was written by write_system_prompt
  // under a BUILD-mode plan.
  buildTransactionId String?
  buildTransaction   BuildTransaction? @relation(fields: [buildTransactionId], references: [id])

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, version(sort: Desc)])
}

// ─── Tool Definitions (per-tenant, system + custom) ─────────────────────────

model ToolDefinition {
  id                 String            @id @default(cuid())
  tenantId           String
  name               String
  displayName        String
  description        String            @db.Text
  defaultDescription String            @db.Text
  parameters         Json
  agentScope         String // "screening" | "coordinator" | "both"
  type               String // "system" | "custom"
  enabled            Boolean           @default(true)
  webhookUrl         String?
  webhookTimeout     Int               @default(10000)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  // Feature 045: set when this tool was created by create_tool_definition
  // under a BUILD-mode plan.
  buildTransactionId String?
  buildTransaction   BuildTransaction? @relation(fields: [buildTransactionId], references: [id])

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

// ─── SOP Definitions (per-tenant, editable by operators) ────────────────────

model SopDefinition {
  id              String   @id @default(cuid())
  tenantId        String
  category        String // e.g., "sop-amenity-request"
  toolDescription String   @db.Text // lean description for AI classification
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants          SopVariant[]
  propertyOverrides SopPropertyOverride[]

  @@unique([tenantId, category])
  @@index([tenantId])
}

model SopVariant {
  id                 String            @id @default(cuid())
  sopDefinitionId    String
  status             String // 'DEFAULT' | 'INQUIRY' | 'CONFIRMED' | 'CHECKED_IN'
  content            String            @db.Text
  enabled            Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  // Feature 045: set when this variant was created via create_sop under a
  // BUILD-mode plan. Kept on the variant (not the definition) because one
  // SopDefinition can collect variants created across multiple plans.
  buildTransactionId String?
  buildTransaction   BuildTransaction? @relation(fields: [buildTransactionId], references: [id])

  sopDefinition SopDefinition @relation(fields: [sopDefinitionId], references: [id], onDelete: Cascade)

  @@unique([sopDefinitionId, status])
}

model SopPropertyOverride {
  id                 String            @id @default(cuid())
  sopDefinitionId    String
  propertyId         String
  status             String // 'DEFAULT' | 'INQUIRY' | 'CONFIRMED' | 'CHECKED_IN'
  content            String            @db.Text
  enabled            Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  // Feature 045: set when this override was created via create_sop
  // (propertyId branch) under a BUILD-mode plan.
  buildTransactionId String?
  buildTransaction   BuildTransaction? @relation(fields: [buildTransactionId], references: [id])

  sopDefinition SopDefinition @relation(fields: [sopDefinitionId], references: [id], onDelete: Cascade)
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([sopDefinitionId, propertyId, status])
}

// ─── Feature 045: BUILD-mode transaction grouping ──────────────────────────
//
// Groups a set of create_sop / create_faq / create_tool_definition /
// write_system_prompt calls that originated from a single
// plan_build_changes approval. Enables atomic rollback across heterogeneous
// artifact types when the manager wants to undo a whole plan.
//
// Status lifecycle: PLANNED → EXECUTING → (COMPLETED | PARTIAL) → ROLLED_BACK.
// PARTIAL = some items succeeded, some failed; rollback reverts what did
// land.
model BuildTransaction {
  id               String    @id @default(cuid())
  tenantId         String
  conversationId   String?
  plannedItems     Json // Array<{ type: 'sop'|'faq'|'system_prompt'|'tool_definition', name, rationale }>
  status           String // PLANNED | EXECUTING | COMPLETED | PARTIAL | ROLLED_BACK
  rationale        String?
  approvedByUserId String? // sprint 045 Gate 5 — set by POST /api/build/plan/:id/approve
  approvedAt       DateTime? // ditto — null until the manager confirms in the UI
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sopVariants          SopVariant[]
  sopPropertyOverrides SopPropertyOverride[]
  faqEntries           FaqEntry[]
  toolDefinitions      ToolDefinition[]
  aiConfigVersions     AiConfigVersion[]

  @@index([tenantId, createdAt])
}

