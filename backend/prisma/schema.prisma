// ─── Feature 040: Copilot Shadow Mode for AI Tuning ─────────────────────────
// All models/enums in this section are additive and nullable-compatible so the
// feature can be retired cleanly by dropping them.

enum PreviewState {
  PREVIEW_PENDING // Unsent preview; actionable IFF it is the latest preview on the conversation
  PREVIEW_LOCKED // Unsent preview superseded by a newer preview
  PREVIEW_SENDING // Brief transition state during Send endpoint; prevents double-send
}

enum TuningActionType {
  EDIT_SYSTEM_PROMPT
  EDIT_SOP_CONTENT
  EDIT_SOP_ROUTING
  EDIT_FAQ
  CREATE_SOP
  CREATE_FAQ
}

enum TuningSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  // Feature 041 sprint 08 §5 — per-category confidence gating.
  // Written when the diagnostic pipeline produces a suggestion in a category
  // whose 30-day acceptance rate is < 30% AND the suggestion's confidence is
  // below the elevated gating threshold (0.75). The row is retained for
  // record-keeping / DPO signal but is hidden from the default queue. Old-
  // branch code never produces this value; code that reads TuningSuggestion
  // must fall through to "treat as non-pending" rather than crash.
  AUTO_SUPPRESSED
}

model TuningSuggestion {
  id               String                 @id @default(cuid())
  tenantId         String
  sourceMessageId  String // Preview Message that triggered the analyzer run
  sourceAiApiLogId String? // Mirrors sourceMessage.aiApiLogId at creation time (convenience)
  actionType       TuningActionType
  status           TuningSuggestionStatus @default(PENDING)
  rationale        String                 @db.Text

  // EDIT action payload (nullable; populated per actionType)
  beforeText   String? @db.Text
  proposedText String? @db.Text

  // Target reference fields
  systemPromptVariant String? // 'coordinator' | 'screening'                 (EDIT_SYSTEM_PROMPT)
  sopCategory         String? // e.g. 'sop-checkin'                          (EDIT_SOP_CONTENT / EDIT_SOP_ROUTING / CREATE_SOP)
  sopStatus           String? // 'DEFAULT'|'INQUIRY'|'CONFIRMED'|'CHECKED_IN' (EDIT_SOP_CONTENT / CREATE_SOP)
  sopPropertyId       String? // Set only when AI consulted a property override (EDIT_SOP_CONTENT)
  sopToolDescription  String? // New classifier description                  (EDIT_SOP_ROUTING / CREATE_SOP)
  faqEntryId          String? // Existing FAQ entry id                       (EDIT_FAQ)

  // CREATE_FAQ payload
  faqCategory   String?
  faqScope      String? // 'GLOBAL' | 'PROPERTY'
  faqPropertyId String?
  faqQuestion   String? @db.Text
  faqAnswer     String? @db.Text

  // Final applied payload (normalized per action type; see data-model.md §3)
  appliedPayload  Json? // e.g. { text } or { question, answer } or { content, toolDescription }
  appliedAt       DateTime?
  appliedByUserId String?

  // ─── Feature 041 extensions (all nullable; old-branch code still inserts without these) ───
  applyMode            String? // 'IMMEDIATE' | 'QUEUED' (string, not enum, to allow future values)
  conversationId       String? // FK to TuningConversation (nullable, SetNull on delete)
  confidence           Float? // 0.0–1.0 verbalized confidence
  appliedAndRetained7d Boolean? // tri-state: null=unknown/too-soon, true/false once checked
  editEmbedding        Unsupported("vector(1536)")? // D1 pre-wire; unused in V1. pgvector 0.8.2 confirmed installed.

  // ─── Feature 041 sprint 02: taxonomy + diagnostic pipeline (all nullable) ───
  // Old-branch code inserts TuningSuggestion rows without these four fields;
  // those rows keep NULL here and remain fully readable/writable by both branches.
  diagnosticCategory TuningDiagnosticCategory? // 8-category taxonomy output
  diagnosticSubLabel String? // Free-form model-generated sub-label within the category
  triggerType        TuningConversationTriggerType? // Originating trigger event (reuses sprint 01 enum)
  evidenceBundleId   String? // FK → EvidenceBundle (SetNull on delete)

  // ─── Feature 041 sprint 08 §4 — critical-failure flag (additive, default false) ───
  // Set by the diagnostic pipeline when a suggestion is high-confidence (>=0.85)
  // AND high-magnitude (WHOLESALE) AND in a content-affecting category
  // (SOP_CONTENT, SOP_ROUTING, SYSTEM_PROMPT). Graduation blocks on any
  // criticalFailure = true in the last 30 days. Old rows default to false;
  // old-branch writes omit the column (default applies). Safe to coexist.
  criticalFailure Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceMessage  Message             @relation("SourcePreview", fields: [sourceMessageId], references: [id], onDelete: Cascade)
  conversation   TuningConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  evidenceBundle EvidenceBundle?     @relation(fields: [evidenceBundleId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([sourceMessageId])
  @@index([conversationId])
  @@index([evidenceBundleId])
  @@index([tenantId, diagnosticCategory])
  // Sprint 09 fix 17 — cooldown query scans ACCEPTED rows by tenant
  // ordered by appliedAt desc; without this index the query falls back
  // to (tenantId, status) + an in-memory sort on appliedAt.
  @@index([tenantId, status, appliedAt(sort: Desc)])
  // Sprint 09 fix 17 — sprint 08 graduation metrics count criticalFailure
  // rows in a 30d window; this composite serves that filter directly.
  @@index([tenantId, criticalFailure, createdAt(sort: Desc)])
}

// ─── Feature 041: Conversational Tuning Agent ────────────────────────────────
// All entities are additive. New tables are safe for coexistence with the live
// `main` branch: it never queries them and its Prisma client is unaffected by
// their presence. See specs/041-conversational-tuning/operational-rules.md.

// Trigger types for TuningConversation + EvidenceBundle. Includes pre-wired
// values (CLUSTER_TRIGGERED, ESCALATION_TRIGGERED) that are not produced by
// V1 code but must exist in the enum so V2 can flip them on without a migration.
enum TuningConversationTriggerType {
  MANUAL
  EDIT_TRIGGERED
  REJECT_TRIGGERED
  COMPLAINT_TRIGGERED
  THUMBS_DOWN_TRIGGERED
  CLUSTER_TRIGGERED // D5 pre-wire; unused in V1
  ESCALATION_TRIGGERED // D6 pre-wire; unused in V1
}

model TuningConversation {
  id              String                        @id @default(cuid())
  tenantId        String
  userId          String? // Pre-wire for agent-initiated conversations (D5) and multi-user (D15). No FK to User: existing project does not have a User model; populated from AuthenticatedRequest.userId.
  title           String?
  triggerType     TuningConversationTriggerType
  anchorMessageId String? // The specific main-AI Message the conversation is anchored to, if any.
  sdkSessionId    String? // Claude Agent SDK persist_session id; populated in sprint 04.
  status          String                        @default("OPEN") // Plain string (not enum) to allow future values without migration.
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  anchorMessage Message?           @relation("AnchorMessage", fields: [anchorMessageId], references: [id], onDelete: SetNull)
  messages      TuningMessage[]
  suggestions   TuningSuggestion[]

  @@index([tenantId])
  @@index([anchorMessageId])
}

model TuningMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String // 'user' | 'assistant' | 'tool' | 'system'
  parts          Json // Vercel AI SDK parts[] (text, tool-call, tool-result, reasoning, data-*)
  createdAt      DateTime @default(now())

  conversation TuningConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model AgentMemory {
  id        String   @id @default(cuid())
  tenantId  String
  key       String // e.g. 'preferences/tone', 'facts/luxury-properties'
  value     Json
  source    String? // Which tuning conversation / suggestion produced this memory
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
}

model EvidenceBundle {
  id          String                        @id @default(cuid())
  tenantId    String
  messageId   String? // Main-AI Message that produced this bundle. Nullable so future non-message-triggered bundles are possible.
  triggerType TuningConversationTriggerType
  payload     Json // Assembled bundle (see evidence-bundle.service.ts → EvidenceBundle type)
  createdAt   DateTime                      @default(now())

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message     Message?           @relation(fields: [messageId], references: [id], onDelete: SetNull)
  suggestions TuningSuggestion[] // sprint 02: suggestions derived from this bundle

  @@index([messageId])
  @@index([tenantId, createdAt(sort: Desc)])
}

model CapabilityRequest {
  id                   String   @id @default(cuid())
  tenantId             String
  title                String
  description          String   @db.Text
  rationale            String?  @db.Text
  sourceConversationId String? // TuningConversation id. Plain string, no FK: request should survive conversation deletion.
  status               String   @default("OPEN")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

// D2 pre-wire: DPO training pairs. V1 does not write to this table.
model PreferencePair {
  id                 String   @id @default(cuid())
  tenantId           String
  context            Json
  rejectedSuggestion Json
  preferredFinal     Json
  category           String?
  createdAt          DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
}

// ─── Feature 041 sprint 02: taxonomy + diagnostic pipeline ──────────────────
// 8-category diagnostic taxonomy produced by the single-call LLM diagnostic
// service. This is a NEW enum and must remain independent of the existing
// `TuningActionType` (which the old `main` branch still uses). Sub-labels are
// free-form strings alongside this enum; do not try to close them.
enum TuningDiagnosticCategory {
  SOP_CONTENT
  SOP_ROUTING
  FAQ
  SYSTEM_PROMPT
  TOOL_CONFIG
  MISSING_CAPABILITY
  PROPERTY_OVERRIDE
  NO_FIX
}

// Per-tenant, per-category acceptance-rate EMA + counts. Updated on every
// accept/reject of a suggestion that carries a `diagnosticCategory`. Old-branch
// code never queries or writes this table.
model TuningCategoryStats {
  id            String                   @id @default(cuid())
  tenantId      String
  category      TuningDiagnosticCategory
  acceptRateEma Float                    @default(0.0)
  acceptCount   Int                      @default(0)
  rejectCount   Int                      @default(0)
  lastUpdatedAt DateTime                 @updatedAt
  createdAt     DateTime                 @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, category])
  @@index([tenantId])
}

// ─── Feature 041 sprint 05: SOP + FAQ version history snapshots ─────────────
//
// Pre-existing SystemPrompt edits live in TenantAiConfig.systemPromptHistory
// (a JSON array). Tool definitions roll back to defaultDescription. SOP
// variants and FAQ entries had no snapshot layer until sprint 05, so the
// rollback path returned 501 NOT_SUPPORTED for those types (concern C17).
// Two additive history tables close the gap. Each capture happens BEFORE the
// mutating write; rollback creates a new history row for the just-overwritten
// state, then writes the snapshot back — same pattern as AiConfigVersion.
//
// targetId is the SopVariant.id / SopPropertyOverride.id / FaqEntry.id at
// snapshot time; previousContent is the JSON snapshot (kind-tagged so SOP
// variants and overrides can share the table); previousMetadata holds the
// classifier/categorical fields so a rollback can restore them too.

model SopVariantHistory {
  id                     String   @id @default(cuid())
  tenantId               String
  targetId               String // SopVariant.id or SopPropertyOverride.id
  previousContent        Json // { kind: 'variant'|'override', sopDefinitionId, status, content, propertyId? }
  previousMetadata       Json?
  editedByUserId         String?
  editedAt               DateTime @default(now())
  triggeringSuggestionId String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, editedAt])
  @@index([targetId])
}

model FaqEntryHistory {
  id                     String   @id @default(cuid())
  tenantId               String
  targetId               String // FaqEntry.id
  previousContent        Json // { question, answer, category, scope, propertyId, status }
  previousMetadata       Json?
  editedByUserId         String?
  editedAt               DateTime @default(now())
  triggeringSuggestionId String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, editedAt])
  @@index([targetId])
}

// ─── Feature 044: WhatsApp doc-handoff state machine ───
// One row per (reservationId, messageType) where messageType ∈ {'REMINDER','HANDOFF'}.
// status is a string (not enum) for forward-compat with new SKIPPED_* reasons without migration.
// See specs/044-doc-handoff-whatsapp/data-model.md for the state machine.
model DocumentHandoffState {
  id                String    @id @default(cuid())
  tenantId          String
  reservationId     String
  messageType       String
  status            String
  scheduledFireAt   DateTime
  attemptCount      Int       @default(0)
  lastError         String?
  providerMessageId String?
  recipientUsed     String?
  messageBodyUsed   String?   @db.Text
  imageUrlsUsed     String[]  @default([])
  sentAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([reservationId, messageType])
  @@index([tenantId])
  @@index([status, scheduledFireAt])
}
