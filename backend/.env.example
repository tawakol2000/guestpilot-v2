# Database
DATABASE_URL="postgresql://user:password@host:5432/guestpilot"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Anthropic / Claude
ANTHROPIC_API_KEY="sk-ant-..."

# Server
PORT=3000
RAILWAY_PUBLIC_DOMAIN="your-app.up.railway.app"

# Optional
NODE_ENV="development"

# Dry run — controls outbound Hostaway message filtering
# DRY_RUN="false"                    → send to anyone (no restrictions)
# DRY_RUN="40570028"                 → only allow this conversation
# DRY_RUN="40570028,12345678"        → allow multiple conversations
DRY_RUN="40570028"
