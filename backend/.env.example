# Database
DATABASE_URL="postgresql://user:password@host:5432/guestpilot"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Anthropic / Claude
ANTHROPIC_API_KEY="sk-ant-..."

# Server
PORT=3000
RAILWAY_PUBLIC_DOMAIN="your-app.up.railway.app"

# Optional
NODE_ENV="development"

# Dry run — set to true to block all outbound Hostaway messages (safe for testing)
DRY_RUN="true"
