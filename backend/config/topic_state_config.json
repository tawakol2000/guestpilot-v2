      "my father", "my mother", "my family", "my kids", "my children",
      "cousin", "uncle", "colleague", "Egyptian", "Saudi", "Kuwaiti",
      "Lebanese", "Jordanian", "Iraqi", "Moroccan", "Emirati",
      "American", "British", "French", "Turkish"
