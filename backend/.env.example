# Database
DATABASE_URL="postgresql://user:password@host:5432/guestpilot"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-this"

# OpenAI — GPT-5.4 Mini for all AI responses (required)
OPENAI_API_KEY="sk-..."

# Server
PORT=3000
RAILWAY_PUBLIC_DOMAIN="your-app.up.railway.app"

# Optional
NODE_ENV="development"

# Redis (BullMQ debounce queue) — add Redis service on Railway, paste URL here
# Without this: system falls back to 30-second poll (graceful degradation)
REDIS_URL=""

# Note: OPENAI_API_KEY above is used for BOTH AI responses AND embeddings.
# Without it: AI pipeline disabled. Embeddings/RAG also disabled.

# (2026-05-15 M20: removed COHERE_API_KEY + the cohere-ai dependency — the
#  Cohere reranking / embeddings path was never implemented, leaving an
#  unused install-time dep and a misleading env var.)

# Langfuse — observability dashboard for AI call tracing and cost tracking
# Without this: tracing is skipped silently
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# Dry run — controls outbound Hostaway message filtering
# DRY_RUN="false"                    → send to anyone (no restrictions)
# DRY_RUN="40570028"                 → only allow this conversation
# DRY_RUN="40570028,12345678"        → allow multiple conversations
DRY_RUN="40570028"

# APNs (Apple Push Notifications) — iOS app push
# Without these: APNs disabled, web push still works
# APNS_AUTH_KEY_BASE64 = base64 of the .p8 AuthKey file from Apple Developer
#   To encode on macOS: base64 -i AuthKey_FVDCUD6CCF.p8 | pbcopy
# APNS_PRODUCTION = "false" for TestFlight/dev builds, "true" for App Store
APNS_AUTH_KEY_BASE64=""
APNS_KEY_ID="FVDCUD6CCF"
APNS_TEAM_ID="JSZ23836RS"
APNS_BUNDLE_ID="com.tawakol.guestpilot"
APNS_PRODUCTION="false"

# ─── Studio agent (BUILD + TUNE) ──────────────────────────────────────────
# The Studio agent assists managers in configuring the AI. It supports two
# provider runtimes, selectable per-request via the in-UI Provider Toggle.

# Provider selector. Default is "anthropic" (Claude Agent SDK).
# Set to "openai" to route Studio turns to the OpenAI Responses API
# (uses OPENAI_API_KEY above — same key as the main pipeline).
STUDIO_PROVIDER="anthropic"

# Optional override for the OpenAI Studio model. Defaults to
# gpt-5.4-mini-2026-03-17.
# STUDIO_OPENAI_MODEL=""

# Required when STUDIO_PROVIDER=anthropic (or when BUILD mode is enabled).
# Studio uses Claude Sonnet 4.6 via the Anthropic Agent SDK.
# Without this: Studio chat is disabled, banner shows the setup gap.
ANTHROPIC_API_KEY=""

# BUILD-mode feature flags. All off by default. Flip ON in staging only.
# ENABLE_BUILD_MODE        — required to expose POST /api/build/* routes
# ENABLE_BUILD_TRACE_VIEW  — admin-only tool-call trace viewer (req. isAdmin)
# ENABLE_RAW_PROMPT_EDITOR — admin-only raw system-prompt drawer (req. isAdmin)
ENABLE_BUILD_MODE=""
ENABLE_BUILD_TRACE_VIEW=""
ENABLE_RAW_PROMPT_EDITOR=""

# Studio direct-transport flag (Sprint 058-A). When "true"/"1"/"yes"/"on"
# the BUILD agent bypasses the Claude Agent SDK and calls @anthropic-ai/sdk
# directly so explicit cache_control markers can be attached to the system
# prompt. Default OFF. Flip on in staging only after canary validation.
BUILD_AGENT_DIRECT_TRANSPORT=""

# Studio pointer-signing HMAC. Studio tools (index/section pointers and
# state-machine transition nonces) HMAC-sign opaque payloads so the agent
# can't forge them. Falls back to JWT_SECRET if unset — set a distinct
# value in production so a JWT_SECRET rotation doesn't accidentally
# invalidate pointers, and so a JWT_SECRET leak doesn't enable pointer
# forgery.
STUDIO_POINTER_HMAC_KEY=""
# STUDIO_TRANSITION_HMAC_KEY=""   # falls back to STUDIO_POINTER_HMAC_KEY

# ─── Feature 044: WhatsApp document handoff (WAsender) ────────────────────
# Without WASENDER_API_KEY: the doc-handoff feature is silently disabled
# (rows are still scheduled but every send is marked SKIPPED_NO_PROVIDER).
WASENDER_API_KEY=""
WASENDER_BASE_URL="https://wasenderapi.com"
WASENDER_TIMEOUT_MS="20000"
